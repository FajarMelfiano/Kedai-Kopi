{
  "entities": {
    "booking": {
      "title": "Booking",
      "description": "Table reservation details",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "date": { "type": "string", "description": "Booking date (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Booking time (HH:mm)" },
        "endTime": { "type": "string", "description": "Booking end time (HH:mm)" },
        "guests": { "type": "integer", "description": "Number of guests" },
        "tableId": { "type": "string", "description": "Selected table identifier" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Booking status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "email", "date", "time", "guests"]
    },
    "menuItem": {
      "title": "Menu Item",
      "description": "Item in the coffee shop menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["coffee", "tea", "pastry", "breakfast"] },
        "image": { "type": "string", "description": "URL to item image" }
      },
      "required": ["name", "price", "category"]
    }
  },
  "firestore": {
    "bookings": {
      "schema": "booking",
      "description": "Collection of table reservations"
    },
    "menu": {
      "schema": "menuItem",
      "description": "Collection of coffee shop menu items"
    }
  }
}
